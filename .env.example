# ============================================
# WAAS - WordPress Affiliate Automation System
# Przykładowy plik konfiguracyjny .env
# ============================================
#
# INSTRUKCJA:
# 1. Skopiuj ten plik i nazwij go ".env"
# 2. Wypełnij swoje prawdziwe dane poniżej
# 3. NIE commituj pliku .env do repozytorium!

# ============================================
# WORDPRESS - Twoja strona WordPress
# ============================================

# URL główny twojej strony WordPress (BEZ końcowego slash)
WORDPRESS_URL=https://twoja-domena.pl

# Użytkownik WordPress z uprawnieniami administratora
WORDPRESS_USERNAME=twoj_admin_username

# Hasło aplikacji WordPress (wygeneruj w: Użytkownicy → Profil → Hasła aplikacji)
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# REST API endpoint WAAS (zwykle nie musisz tego zmieniać)
WORDPRESS_REST_API_BASE=https://twoja-domena.pl/wp-json/waas/v1


# ============================================
# AMAZON PA-API 5.0 - Product Advertising API
# ============================================
# Zarejestruj się tutaj: https://affiliate-program.amazon.com/assoc_credentials/home

# Access Key (20 znaków alfanumerycznych)
# Przykład: AKIAIOSFODNN7EXAMPLE
AMAZON_PA_API_ACCESS_KEY=TWOJ_ACCESS_KEY_TUTAJ

# Secret Key (40 znaków)
# Przykład: wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AMAZON_PA_API_SECRET_KEY=TWOJ_SECRET_KEY_TUTAJ

# Associate Tag / Tracking ID (np. yoursite-20)
# Znajdziesz w Amazon Associates: Tools → Product Linking → Site Stripe
AMAZON_ASSOCIATE_TAG=yoursite-20

# Amazon Region (wybierz swój marketplace)
# Opcje: us-east-1 (USA), eu-west-1 (UK), us-west-2 (CA), ap-northeast-1 (JP), eu-central-1 (DE)
AMAZON_REGION=us-east-1


# ============================================
# GOOGLE SHEETS - Integracja z Google Sheets
# ============================================

# ID Twojego Google Sheets (znajdziesz w URL arkusza)
# URL: https://docs.google.com/spreadsheets/d/1abc...xyz/edit
# ID to część: 1abc...xyz
GOOGLE_SHEETS_ID=TWOJ_GOOGLE_SHEETS_ID

# URL Web App Deployment Google Apps Script
# Otrzymasz po wdrożeniu Web App w Apps Script
# Przykład: https://script.google.com/macros/s/AKfycby.../exec
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=https://script.google.com/macros/s/TWOJ_DEPLOYMENT_ID/exec

# Klucz API do zabezpieczenia komunikacji (wymyśl własny, min. 20 znaków)
# WAŻNE: Ten sam klucz wpisz w Google Sheets w karcie Settings!
GOOGLE_SHEETS_API_KEY=moj-super-tajny-klucz-api-2025-xyz


# ============================================
# HOSTINGER - Konfiguracja hostingu
# ============================================

# FTP/SFTP Hostname
HOSTINGER_FTP_HOST=ftp.twoja-domena.pl

# FTP/SFTP Username
HOSTINGER_FTP_USER=u123456789

# FTP/SFTP Password
HOSTINGER_FTP_PASSWORD=TwojeSilneHaslo123!

# FTP/SFTP Port (zwykle 21 dla FTP, 22 dla SFTP)
HOSTINGER_FTP_PORT=21

# Ścieżka do katalogu WordPress na serwerze
HOSTINGER_WP_PATH=/public_html/


# ============================================
# DIVI THEME - Konfiguracja motywu Divi
# ============================================

# Czy używasz Divi Builder (true/false)
DIVI_ENABLED=true

# ID modułu Divi używanego do wyświetlania produktów (opcjonalnie)
DIVI_PRODUCT_MODULE_ID=

# ============================================
# ELEGANT THEMES - Aktywacja licencji Divi
# ============================================
# Te dane są potrzebne do automatycznej aktywacji licencji Divi
# po zainstalowaniu motywu na nowej stronie

# Username konta Elegant Themes (https://www.elegantthemes.com)
ELEGANT_THEMES_USERNAME=twoj_username@example.com

# Hasło do konta Elegant Themes
ELEGANT_THEMES_PASSWORD=TwojeHasloElegantThemes123!


# ============================================
# PLUGIN DO PRODUKTÓW - Twój obecny plugin
# ============================================
# Jeśli już używasz jakiegoś pluginu do wstawiania produktów jako shortcode

# Nazwa pluginu (np. AAWP, Lasso, ProductPusher)
CURRENT_PRODUCT_PLUGIN_NAME=AAWP

# Shortcode używany przez ten plugin
CURRENT_PRODUCT_SHORTCODE=aawp

# Czy migrować z obecnego pluginu do WAAS (true/false)
MIGRATE_FROM_CURRENT_PLUGIN=false


# ============================================
# BEZPIECZEŃSTWO
# ============================================

# Tajny klucz do szyfrowania (wygeneruj losowy ciąg min. 32 znaków)
# Możesz użyć: https://www.random.org/strings/?num=1&len=32&digits=on&upperalpha=on&loweralpha=on
SECRET_ENCRYPTION_KEY=WYGENERUJ_LOSOWY_CIAG_32_ZNAKOW

# Klucz do WordPress REST API (opcjonalny dodatkowy layer bezpieczeństwa)
WP_REST_API_KEY=twoj-rest-api-key-123


# ============================================
# ZAAWANSOWANE - Opcjonalne ustawienia
# ============================================

# Debug mode (true włącza szczegółowe logi, false wyłącza)
DEBUG_MODE=false

# Cache duration in hours (default: 24, zgodnie z Amazon TOS)
CACHE_DURATION_HOURS=24

# Max products to sync at once
MAX_SYNC_BATCH_SIZE=50

# Cron schedule for daily sync (format: H:i, np. 02:00 dla 2:00 w nocy)
CRON_SYNC_TIME=02:00


# ============================================
# PRZYKŁADOWE DANE DO TESTÓW
# ============================================

# Testowy ASIN do sprawdzenia połączenia z Amazon PA-API
TEST_ASIN=B08N5WRWNW

# Testowa kategoria produktów
TEST_CATEGORY=electronics


# ============================================
# UWAGI KOŃCOWE
# ============================================
#
# 🔒 BEZPIECZEŃSTWO:
# - NIE udostępniaj tego pliku publicznie!
# - Dodaj .env do .gitignore
# - Używaj silnych haseł i kluczy (min. 20 znaków)
#
# 📝 GDZIE ZNALEŹĆ DANE:
# - Amazon PA-API: https://affiliate-program.amazon.com/assoc_credentials/home
# - WordPress App Password: WP Admin → Użytkownicy → Profil → Hasła aplikacji
# - Hostinger FTP: Panel Hostinger → FTP Accounts
# - Google Sheets ID: Patrz URL arkusza (część między /d/ a /edit)
# - Elegant Themes: Twoje dane logowania z https://www.elegantthemes.com
#
# 🚀 WIĘCEJ INFORMACJI:
# - Przeczytaj README.md
# - Zobacz dokumentację w /docs
# - Sprawdź Google Apps Script README_GoogleAppsScript.md
