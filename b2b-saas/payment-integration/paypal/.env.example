# PayPal Configuration
PAYPAL_CLIENT_ID=your-client-id-here
PAYPAL_CLIENT_SECRET=your-client-secret-here
PAYPAL_WEBHOOK_ID=your-webhook-id-here
PAYPAL_MODE=sandbox  # sandbox or live

# WordPress API Configuration
WORDPRESS_API_URL=https://yourdomain.com/wp-json/waas/v1
WORDPRESS_API_KEY=your-wordpress-api-key-here

# Application Configuration
PORT=5001
FLASK_ENV=production
LOG_LEVEL=INFO
