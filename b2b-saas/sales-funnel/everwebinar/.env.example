# EverWebinar Configuration
EVERWEBINAR_API_KEY=your-everwebinar-api-key
EVERWEBINAR_WEBINAR_ID=your-webinar-id

# Email Automation (Kartra or alternative)
KARTRA_API_KEY=your-kartra-api-key
KARTRA_API_URL=https://app.kartra.com/api

# Application
PORT=5004
FLASK_ENV=production

# Payment Links
STRIPE_CHECKOUT_URL=https://checkout.stripe.com/pay/xxxxx
PAYPAL_CHECKOUT_URL=https://www.paypal.com/xxxxx

# Website URLs
WEBINAR_REPLAY_URL=https://yoursite.com/webinar/replay
CHECKOUT_URL=https://yoursite.com/checkout
